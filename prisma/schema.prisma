generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model highlighted_ips {
  id         Int       @id @default(autoincrement())
  ip_address String    @unique @db.VarChar
  reason     String?   @db.VarChar
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model internal_infrastructure_assets {
  id                    Int    @id @default(autoincrement())
  asset_name            String @db.VarChar
  host_identifier_local String @db.VarChar
  department_owner      String @db.VarChar
  risk_level            String @db.VarChar
}